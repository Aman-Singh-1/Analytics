# Copy to .env and fill in. Only GROQ_API_KEY is required to run the API.
GROQ_API_KEY=

LLM_MODEL=llama-3.3-70b-versatile
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

TOP_K=8
RERANK_TOP_N=4
USE_RERANKER=true
SIM_THRESHOLD=0.66

INDEX_DIR=data/faiss_index
# cap docs in the index (0 = all). small caps build fast for demos.
INDEX_MAX_DOCS=0

CACHE_SIZE=512
CACHE_TTL=3600

LOG_LEVEL=INFO
